# ─── Server ───────────────────────────────────────────────────────────────────
PORT=4000
NODE_ENV=development
# Comma-separated list of allowed mobile / web origins for CORS.
CORS_ORIGINS=http://localhost:8081,http://localhost:19006

# ─── Database ─────────────────────────────────────────────────────────────────
DATABASE_URL=postgresql://postgres:postgres@localhost:5432/ai_concierge?schema=public

# ─── Auth ─────────────────────────────────────────────────────────────────────
JWT_SECRET=replace-me-with-a-32-byte-random-string
JWT_EXPIRES_IN=7d

# ─── Google Sign-In ───────────────────────────────────────────────────────────
# Comma-separated OAuth client IDs the backend accepts as the audience when
# verifying Google ID tokens. Include the Web client ID (used by the mobile app
# as `webClientId`) plus the iOS and Android client IDs.
GOOGLE_CLIENT_IDS=replace_me.apps.googleusercontent.com

# ─── Email (Nodemailer) ───────────────────────────────────────────────────────
# Sends the 6-digit signup verification code. Nodemailer uses a well-known
# service (default: gmail). For Gmail, use your address as MAIL_USER and a
# Google App Password as MAIL_PASS.
MAIL_SERVICE=gmail
MAIL_USER=replace_me@gmail.com
MAIL_PASS=replace_me
# From address shown to recipients. Defaults to MAIL_USER if omitted.
MAIL_FROM=AI Concierge <no-reply@example.com>
# Minutes a verification code stays valid before expiring.
EMAIL_CODE_TTL_MINUTES=10

# ─── Encryption (AES-256-GCM, 32-byte key, hex or base64) ─────────────────────
# Used to encrypt CRM tokens and OpenAI API keys at rest.
ENCRYPTION_KEY=replace-me-with-a-32-byte-key-hex

# ─── Stripe ───────────────────────────────────────────────────────────────────
STRIPE_SECRET_KEY=sk_test_replace_me
STRIPE_PUBLISHABLE_KEY=pk_test_replace_me
STRIPE_WEBHOOK_SECRET=whsec_replace_me
# Stripe Price IDs for each CRM plan (create them in the Stripe dashboard).
STRIPE_PRICE_GHL=price_replace_me
STRIPE_PRICE_HUBSPOT=price_replace_me

# ─── GoHighLevel OAuth ────────────────────────────────────────────────────────
GHL_CLIENT_ID=replace_me
GHL_CLIENT_SECRET=replace_me
# Must match Marketplace Redirect URL exactly (trailing slash if registered).
# Prod (requires nginx — see deploy/README.md): https://borncreative.net/
GHL_REDIRECT_URI=https://borncreative.net/
# Local dev (second URL in GHL Marketplace): http://<LAN-ip>:4000/oauth/callback
# Space-separated GHL scopes requested at authorization time.
# Must match scopes selected in Marketplace → Advanced Settings → Auth.
GHL_SCOPES=contacts.readonly contacts.write calendars.readonly calendars.write calendars/events.readonly calendars/events.write calendars/groups.readonly calendars/groups.write calendars/resources.readonly calendars/resources.write opportunities.readonly opportunities.write
# Fallback IANA timezone when booking if the sub-account calendar has none (e.g. America/New_York).
# GHL_CALENDAR_TIMEZONE=America/New_York

# ─── App deep link ────────────────────────────────────────────────────────────
# Used by the OAuth callback HTML to redirect users back into the mobile app.
APP_DEEP_LINK_SCHEME=aiconcierge

# ─── HubSpot OAuth ────────────────────────────────────────────────────────────
HUBSPOT_CLIENT_ID=replace_me
HUBSPOT_CLIENT_SECRET=replace_me
HUBSPOT_REDIRECT_URI=http://localhost:4000/integrations/hubspot/callback
# Space-separated HubSpot scopes requested at authorization time.
HUBSPOT_SCOPES=crm.objects.contacts.read crm.objects.contacts.write crm.objects.deals.read crm.objects.deals.write crm.objects.companies.read crm.objects.companies.write oauth
