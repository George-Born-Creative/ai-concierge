# ─── Server ───────────────────────────────────────────────────────────────────
PORT=4000
NODE_ENV=development
# Comma-separated list of allowed mobile / web origins for CORS.
CORS_ORIGINS=http://localhost:8081,http://localhost:19006

# ─── Database ─────────────────────────────────────────────────────────────────
DATABASE_URL=postgresql://postgres:postgres@localhost:5432/ai_concierge?schema=public

# ─── Auth ─────────────────────────────────────────────────────────────────────
JWT_SECRET=replace-me-with-a-32-byte-random-string
JWT_EXPIRES_IN=7d

# ─── Encryption (AES-256-GCM, 32-byte key, hex or base64) ─────────────────────
# Used to encrypt CRM tokens and OpenAI API keys at rest.
ENCRYPTION_KEY=replace-me-with-a-32-byte-key-hex

# ─── Stripe ───────────────────────────────────────────────────────────────────
STRIPE_SECRET_KEY=sk_test_replace_me
STRIPE_PUBLISHABLE_KEY=pk_test_replace_me
STRIPE_WEBHOOK_SECRET=whsec_replace_me
# Stripe Price IDs for each CRM plan (create them in the Stripe dashboard).
STRIPE_PRICE_GHL=price_replace_me
STRIPE_PRICE_HUBSPOT=price_replace_me

# ─── GoHighLevel OAuth ────────────────────────────────────────────────────────
GHL_CLIENT_ID=replace_me
GHL_CLIENT_SECRET=replace_me
GHL_REDIRECT_URI=http://localhost:4000/integrations/ghl/callback

# ─── HubSpot OAuth ────────────────────────────────────────────────────────────
HUBSPOT_CLIENT_ID=replace_me
HUBSPOT_CLIENT_SECRET=replace_me
HUBSPOT_REDIRECT_URI=http://localhost:4000/integrations/hubspot/callback
