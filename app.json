{
  "expo": {
    "name": "ai-concierge",
    "slug": "ai-concierge",
    "version": "1.0.0",
    "orientation": "portrait",
    "scheme": "aiconcierge",
    "userInterfaceStyle": "light",
    "backgroundColor": "#F8FAFF",
    "newArchEnabled": true,
    "ios": {
      "supportsTablet": true,
      "infoPlist": {
        "NSMicrophoneUsageDescription": "AI Concierge uses the microphone to record voice commands before sending them to chat."
      }
    },
    "android": {
      "usesCleartextTraffic": true,
      "intentFilters": [
        {
          "action": "VIEW",
          "autoVerify": true,
          "data": [
            {
              "scheme": "aiconcierge",
              "host": "oauth",
              "pathPrefix": "/"
            }
          ],
          "category": [
            "BROWSABLE",
            "DEFAULT"
          ]
        }
      ],
      "permissions": [
        "android.permission.RECORD_AUDIO"
      ],
      "edgeToEdgeEnabled": true,
      "predictiveBackGestureEnabled": false,
      "package": "com.daveget.aiconcierge"
    },
    "web": {
      "output": "static"
    },
    "plugins": [
      "expo-router",
      [
        "@stripe/stripe-react-native",
        {
          "enableGooglePay": false,
          "merchantIdentifier": []
        }
      ],
      "expo-secure-store",
      "expo-iap"
    ],
    "experiments": {
      "typedRoutes": true,
      "reactCompiler": true
    },
    "extra": {
      "router": {},
      "eas": {
        "projectId": "b26e4552-7b6d-4281-8335-e45229df8dae"
      }
    }
  }
}
