{
  "expo": {
    "name": "ai-concierge",
    "slug": "ai-concierge",
    "version": "1.0.0",
    "orientation": "portrait",
    "icon": "./assets/images/icon.png",
    "scheme": "aiconcierge",
    "userInterfaceStyle": "automatic",
    "newArchEnabled": true,
    "ios": {
      "supportsTablet": true,
      "infoPlist": {
        "NSMicrophoneUsageDescription": "AI Concierge uses the microphone to record voice commands before sending them to chat."
      }
    },
    "android": {
      "usesCleartextTraffic": true,
      "intentFilters": [
        {
          "action": "VIEW",
          "autoVerify": true,
          "data": [
            {
              "scheme": "aiconcierge",
              "host": "oauth",
              "pathPrefix": "/"
            }
          ],
          "category": [
            "BROWSABLE",
            "DEFAULT"
          ]
        }
      ],
      "permissions": [
        "android.permission.RECORD_AUDIO"
      ],
      "adaptiveIcon": {
        "backgroundColor": "#E6F4FE",
        "foregroundImage": "./assets/images/android-icon-foreground.png",
        "backgroundImage": "./assets/images/android-icon-background.png",
        "monochromeImage": "./assets/images/android-icon-monochrome.png"
      },
      "edgeToEdgeEnabled": true,
      "predictiveBackGestureEnabled": false,
      "package": "com.daveget.aiconcierge"
    },
    "web": {
      "output": "static",
      "favicon": "./assets/images/favicon.png"
    },
    "plugins": [
      "expo-router",
      [
        "expo-splash-screen",
        {
          "image": "./assets/images/ai-concierge-splash.png",
          "imageWidth": 423,
          "resizeMode": "cover",
          "backgroundColor": "#05051D",
          "dark": {
            "image": "./assets/images/ai-concierge-splash.png",
            "backgroundColor": "#05051D"
          }
        }
      ],
      [
        "@stripe/stripe-react-native",
        {
          "enableGooglePay": false,
          "merchantIdentifier": []
        }
      ],
      "expo-secure-store"
    ],
    "experiments": {
      "typedRoutes": true,
      "reactCompiler": true
    },
    "extra": {
      "router": {},
      "eas": {
        "projectId": "b26e4552-7b6d-4281-8335-e45229df8dae"
      }
    }
  }
}
