{
  "expo": {
    "name": "ai-concierge",
    "slug": "konvero-ai-concierge",
    "version": "1.0.0",
    "orientation": "portrait",
    "scheme": "aiconcierge",
    "userInterfaceStyle": "automatic",
    "backgroundColor": "#F8FAFF",
    "icon": "./assets/images/icon.png",
    "newArchEnabled": true,
    "ios": {
      "supportsTablet": true,
      "infoPlist": {
        "NSMicrophoneUsageDescription": "AI Concierge uses the microphone to record voice commands before sending them to chat.",
        "NSCameraUsageDescription": "AI Concierge uses the camera for real-time voice/video sessions with the AI agent.",
        "ITSAppUsesNonExemptEncryption": false
      },
      "bundleIdentifier": "ai.konvero.app"
    },
    "android": {
      "intentFilters": [
        {
          "action": "VIEW",
          "autoVerify": true,
          "data": [
            {
              "scheme": "aiconcierge",
              "host": "oauth",
              "pathPrefix": "/"
            }
          ],
          "category": [
            "BROWSABLE",
            "DEFAULT"
          ]
        }
      ],
      "permissions": [
        "android.permission.RECORD_AUDIO",
        "android.permission.CAMERA",
        "android.permission.ACCESS_NETWORK_STATE",
        "android.permission.MODIFY_AUDIO_SETTINGS",
        "android.permission.WAKE_LOCK",
        "android.permission.BLUETOOTH",
        "android.permission.POST_NOTIFICATIONS",
        "android.permission.SCHEDULE_EXACT_ALARM",
        "android.permission.USE_EXACT_ALARM",
        "android.permission.RECEIVE_BOOT_COMPLETED"
      ],
      "edgeToEdgeEnabled": true,
      "predictiveBackGestureEnabled": false,
      "package": "com.daveget.aiconcierge",
      "adaptiveIcon": {
        "foregroundImage": "./assets/images/icon.png",
        "backgroundColor": "#F8FAFF"
      }
    },
    "web": {
      "output": "static"
    },
    "plugins": [
      "expo-router",
      [
        "@stripe/stripe-react-native",
        {
          "enableGooglePay": false,
          "merchantIdentifier": []
        }
      ],
      "expo-secure-store",
      "expo-iap",
      "@react-native-community/datetimepicker",
      [
        "expo-splash-screen",
        {
          "image": "./assets/images/icon.png",
          "imageWidth": 200,
          "resizeMode": "contain",
          "backgroundColor": "#F8FAFF",
          "dark": {
            "image": "./assets/images/icon.png",
            "backgroundColor": "#0B1220"
          }
        }
      ],
      [
        "expo-notifications",
        {
          "color": "#1F49E0",
          "defaultChannel": "reminders"
        }
      ],
      "@react-native-google-signin/google-signin"
    ],
    "experiments": {
      "typedRoutes": true,
      "reactCompiler": true
    },
    "extra": {
      "router": {},
      "eas": {
        "projectId": "36716986-3765-40ed-9a5f-3a8795eb5800"
      }
    },
    "owner": "georgeact"
  }
}
