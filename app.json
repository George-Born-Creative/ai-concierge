{
  "expo": {
    "name": "ai-concierge",
    "slug": "ai-concierge",
    "version": "1.0.0",
    "orientation": "portrait",
    "icon": "./assets/images/icon.png",
    "scheme": "aiconcierge",
    "userInterfaceStyle": "automatic",
    "newArchEnabled": true,
    "ios": {
      "supportsTablet": true,
      "infoPlist": {
        "NSContactsUsageDescription": "AI Concierge uses contacts to fetch, identify, create, and delete contacts from your commands.",
        "NSMicrophoneUsageDescription": "AI Concierge uses the microphone to record voice commands before sending them to chat."
      }
    },
    "android": {
      "permissions": [
        "android.permission.READ_CONTACTS",
        "android.permission.WRITE_CONTACTS",
        "android.permission.RECORD_AUDIO"
      ],
      "adaptiveIcon": {
        "backgroundColor": "#E6F4FE",
        "foregroundImage": "./assets/images/android-icon-foreground.png",
        "backgroundImage": "./assets/images/android-icon-background.png",
        "monochromeImage": "./assets/images/android-icon-monochrome.png"
      },
      "edgeToEdgeEnabled": true,
      "predictiveBackGestureEnabled": false
    },
    "web": {
      "output": "static",
      "favicon": "./assets/images/favicon.png"
    },
    "plugins": [
      "expo-router",
      [
        "expo-splash-screen",
        {
          "image": "./assets/images/ai-concierge-splash.png",
          "imageWidth": 423,
          "resizeMode": "cover",
          "backgroundColor": "#05051D",
          "dark": {
            "image": "./assets/images/ai-concierge-splash.png",
            "backgroundColor": "#05051D"
          }
        }
      ],
      [
        "@stripe/stripe-react-native",
        {
          "enableGooglePay": false,
          "merchantIdentifier": []
        }
      ],
      "expo-secure-store"
    ],
    "experiments": {
      "typedRoutes": true,
      "reactCompiler": true
    }
  }
}
