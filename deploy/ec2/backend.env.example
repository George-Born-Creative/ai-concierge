# Dedicated EC2 backend host example.
# Values with spaces are quoted so the same file works for:
# - NestJS dotenv loading
# - Prisma CLI
# - systemd EnvironmentFile=

PORT=4000
HOST=127.0.0.1
NODE_ENV=production

# Leave blank if only the native mobile app calls this API.
CORS_ORIGINS=""

DATABASE_URL="postgresql://ai_concierge:replace_me@127.0.0.1:5432/ai_concierge?schema=public"

JWT_SECRET="replace-with-a-32-byte-random-string"
JWT_EXPIRES_IN="7d"
ENCRYPTION_KEY="replace-with-a-32-byte-hex-string"

# ─── Google Sign-In ───────────────────────────────────────────────────────────
# Comma-separated OAuth client IDs accepted as the ID-token audience (Web + iOS
# + Android). The Web client ID is also the mobile app's `webClientId`.
GOOGLE_CLIENT_IDS="replace_me.apps.googleusercontent.com"

# ─── Email (Nodemailer) ───────────────────────────────────────────────────────
# Nodemailer service transport for the signup verification code (default gmail).
# For Gmail use your address as MAIL_USER and a Google App Password as MAIL_PASS.
MAIL_SERVICE="gmail"
MAIL_USER="replace_me@gmail.com"
MAIL_PASS="replace_me"
MAIL_FROM="AI Concierge <noreply@example.com>"
EMAIL_CODE_TTL_MINUTES="10"

# Monitored Help & Support destination and retention/retry policy.
SUPPORT_INBOX_EMAIL="support@example.com"
SUPPORT_REQUEST_RETENTION_DAYS="180"
SUPPORT_DELIVERY_MAX_ATTEMPTS="5"
SUPPORT_DELIVERY_BATCH_SIZE="25"

STRIPE_SECRET_KEY="sk_live_replace_me"
STRIPE_PUBLISHABLE_KEY="pk_live_replace_me"
STRIPE_WEBHOOK_SECRET="whsec_replace_me"
STRIPE_PRICE_GHL="price_replace_me"
STRIPE_PRICE_HUBSPOT="price_replace_me"

GHL_CLIENT_ID="replace_me"
GHL_CLIENT_SECRET="replace_me"
GHL_REDIRECT_URI="https://api.example.com/oauth/callback"
GHL_SCOPES="contacts.readonly contacts.write calendars.readonly calendars.write calendars/events.readonly calendars/events.write calendars/groups.readonly calendars/groups.write calendars/resources.readonly calendars/resources.write opportunities.readonly opportunities.write"

APP_DEEP_LINK_SCHEME="aiconcierge"

HUBSPOT_CLIENT_ID="replace_me"
HUBSPOT_CLIENT_SECRET="replace_me"
HUBSPOT_REDIRECT_URI="https://api.example.com/integrations/hubspot/callback"
HUBSPOT_SCOPES="crm.objects.contacts.read crm.objects.contacts.write crm.objects.deals.read crm.objects.deals.write crm.objects.companies.read crm.objects.companies.write oauth"

# ─── Apple In-App Purchase ────────────────────────────────────────────────────
# App Store Connect → Users and Access → Integrations → Keys (In-App Purchase).
# APPLE_PRIVATE_KEY is the P8 contents; use literal "\n" between rows so
# systemd EnvironmentFile= can parse the value on a single line.
APPLE_BUNDLE_ID="com.daveget.aiconcierge"
APPLE_TEAM_ID="replace_me"
APPLE_KEY_ID="replace_me"
APPLE_PRIVATE_KEY="-----BEGIN PRIVATE KEY-----\nreplace_me\n-----END PRIVATE KEY-----"
# Use "Sandbox" for TestFlight / sandbox testers, "Production" for the App
# Store. The two environments sign with different Apple roots, so this must
# match the build of the app sending the receipt.
APPLE_ENV="Sandbox"
APPLE_NOTIFICATION_AUDIENCE="com.daveget.aiconcierge"
